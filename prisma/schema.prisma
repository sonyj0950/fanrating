// 스포츠 평점 사이트 — Prisma 스키마 (PostgreSQL — Neon/Supabase 등)
// 로컬 개발도 같은 Neon DB를 써도 되고, 별도 DB를 .env에 지정해도 됩니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  username  String        @unique // 로그인용 아이디
  nickname  String        @unique // 표시용 닉네임
  password  String // bcrypt 해시
  role      String        @default("user") // "admin" | "user"
  createdAt DateTime      @default(now())
  ratings   Rating[]
  replies   Reply[]
  likes     CommentLike[]
  reports   Report[]
}

model Match {
  id        String        @id @default(cuid())
  sport     String // "kbo" | "kleague" | "lck"
  date      DateTime
  homeTeam  String
  awayTeam  String
  homeScore Int?
  awayScore Int?
  status    String        @default("scheduled") // scheduled | live | finished
  record    String? // ⚽ 골·어시스트 기록 (줄 단위 텍스트)
  createdAt DateTime      @default(now())
  players   MatchPlayer[]
  ratings   Rating[]
}

model Player {
  id       String        @id @default(cuid())
  name     String
  team     String
  position String?
  matches  MatchPlayer[]
  ratings  Rating[]
}

model MatchPlayer {
  id        String  @id @default(cuid())
  matchId   String
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id])
  role      String?
  isDefault Boolean @default(true) // 야구: 우선 노출 선수
  segment   String  @default("all") // 출전: all | first(전반) | second(후반)
  posX      Float?  // 관리자 커스텀 위치 (%) — null이면 포지션 코드 기준 자동 배치
  posY      Float?

  @@unique([matchId, playerId])
}

model Rating {
  id        String        @id @default(cuid())
  matchId   String
  match     Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player        @relation(fields: [playerId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  segment   String        @default("full") // full | first | second | set1...set5
  score     Int // 2~9
  comment   String        @default("") // 선택 사항 (빈 문자열 허용)
  blinded   Boolean       @default(false) // 신고 누적/관리자 처리로 가려진 상태
  createdAt DateTime      @default(now())
  replies   Reply[]
  likes     CommentLike[]
  reports   Report[]

  @@unique([matchId, playerId, userId, segment]) // 유저당 세그먼트별 1회 (재등록 시 갱신)
}

// 대댓글
model Reply {
  id        String   @id @default(cuid())
  ratingId  String
  rating    Rating   @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

// 코멘트 좋아요 (유저당 1회, 재클릭 시 취소)
model CommentLike {
  id       String @id @default(cuid())
  ratingId String
  rating   Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@unique([ratingId, userId])
}

// 코멘트 신고 (유저당 코멘트별 1회)
model Report {
  id        String   @id @default(cuid())
  ratingId  String
  rating    Rating   @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reason    String   @default("")
  createdAt DateTime @default(now())

  @@unique([ratingId, userId])
}
