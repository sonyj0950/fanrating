// 스포츠 평점 사이트 — Prisma 스키마 (PostgreSQL — Neon/Supabase 등)
// 로컬 개발도 같은 Neon DB를 써도 되고, 별도 DB를 .env에 지정해도 됩니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  username  String        @unique // 로그인용 아이디
  nickname  String        @unique // 표시용 닉네임
  password  String // bcrypt 해시
  role      String        @default("user") // "admin" | "user"
  createdAt DateTime      @default(now())
  ratings   Rating[]
  replies   Reply[]
  likes     CommentLike[]
  reports   Report[]
  discussions DiscussionComment[]
  discussionReplies DiscussionReply[]
  discussionLikes DiscussionLike[]
  discussionReports DiscussionReport[]
}

model Match {
  id        String        @id @default(cuid())
  sport     String // "kbo" | "kleague" | "lck"
  date      DateTime
  homeTeam  String
  awayTeam  String
  homeScore Int?
  awayScore Int?
  status    String        @default("scheduled") // scheduled | live | finished
  round     String? // 🏷 라운드/단계 라벨 (예: "프리미어리그 7라운드", "LCK 4라운드", "KBO 플레이오프 2차전")
  record    String? // ⚽ 골·어시스트 기록 (줄 단위 텍스트)
  seed      String? // 🔥 자동 생성된 토론거리 (경기 종료 후)
  setResults Json? // 🎮 LCK 세트별 승팀 (관리자 입력) — { "set1": "home" | "away", ... }
  createdAt DateTime      @default(now())
  players   MatchPlayer[]
  ratings   Rating[]
  discussions DiscussionComment[]
  substitutions Substitution[]
}

// 교체 정보: 몇 분에 누가 나가고(out) 누가 들어왔는지(in)
model Substitution {
  id          String  @id @default(cuid())
  matchId     String
  minute      Int     // 교체 시각 (분) — ⚾ KBO에서는 이닝으로 재사용
  outPlayerId String  // 나간 선수 (Player.id)
  inPlayerId  String  // 들어온 선수 (Player.id)
  kind        String? // ⚾ KBO 교체 종류: 대타 | 대주자 | 투수교체 | 수비교체
  match       Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  @@index([matchId])
}

// 경기 토론 댓글 (시드 배너 아래 자유 토론 — 선수 평점과 별개)
model DiscussionComment {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  blinded   Boolean  @default(false)
  createdAt DateTime @default(now())
  replies   DiscussionReply[]
  likes     DiscussionLike[]
  reports   DiscussionReport[]

  @@index([matchId])
}

model DiscussionReply {
  id        String   @id @default(cuid())
  commentId String
  comment   DiscussionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model DiscussionLike {
  id        String   @id @default(cuid())
  commentId String
  comment   DiscussionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  @@unique([commentId, userId])
}

model DiscussionReport {
  id        String   @id @default(cuid())
  commentId String
  comment   DiscussionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reason    String   @default("")
  createdAt DateTime @default(now())
  @@unique([commentId, userId])
}

model Player {
  id           String        @id @default(cuid())
  name         String
  team         String
  position     String?
  isPitcher    Boolean? // ⚾ KBO: 투수 true / 타자 false (그 외 종목은 null)
  rosterActive Boolean       @default(true) // ⚾ KBO 1군 등록 여부 (월요일 로스터 갱신 시 토글)
  matches      MatchPlayer[]
  ratings      Rating[]
}

model MatchPlayer {
  id        String  @id @default(cuid())
  matchId   String
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id])
  role      String?
  isDefault Boolean @default(true) // 야구: 우선 노출 선수
  segment   String  @default("all") // 출전: all | first(전반) | second(후반)
  posX      Float?  // 관리자 커스텀 위치 (%) — null이면 포지션 코드 기준 자동 배치
  posY      Float?
  champions Json?   // 🎮 LCK 세트별 챔피언 — { "set1": "Vayne", "set2": "Kaisa", ... }
  battingOrder Int? // ⚾ KBO 타순 1~9 (투수·벤치는 null)

  @@unique([matchId, playerId])
}

model Rating {
  id        String        @id @default(cuid())
  matchId   String
  match     Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player        @relation(fields: [playerId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  segment   String        @default("full") // full | first | second | set1...set5
  score     Int // 2~9
  comment   String        @default("") // 선택 사항 (빈 문자열 허용)
  blinded   Boolean       @default(false) // 신고 누적/관리자 처리로 가려진 상태
  createdAt DateTime      @default(now())
  replies   Reply[]
  likes     CommentLike[]
  reports   Report[]

  @@unique([matchId, playerId, userId, segment]) // 유저당 세그먼트별 1회 (재등록 시 갱신)
}

// 대댓글
model Reply {
  id        String   @id @default(cuid())
  ratingId  String
  rating    Rating   @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

// 코멘트 좋아요 (유저당 1회, 재클릭 시 취소)
model CommentLike {
  id       String @id @default(cuid())
  ratingId String
  rating   Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@unique([ratingId, userId])
}

// 코멘트 신고 (유저당 코멘트별 1회)
model Report {
  id        String   @id @default(cuid())
  ratingId  String
  rating    Rating   @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reason    String   @default("")
  createdAt DateTime @default(now())

  @@unique([ratingId, userId])
}

// 구단 색상 오버라이드 (관리자가 공식색을 바꿨을 때만 행 존재. 없으면 공식색/폴백)
model TeamColor {
  team  String @id // Player.team / Match.homeTeam 과 같은 표준 팀 문자열
  color String     // hex (#RRGGBB)
}

// 리그 순위표 (EPL=자동/API, KBO·LCK=관리자 수동). 갱신 시 해당 league 행 전체 교체.
model Standing {
  id     String   @id @default(cuid())
  league String // epl | kbo | lck | kleague
  rank   Int
  team   String
  played Int?
  win    Int?
  draw   Int?
  loss   Int?
  points Int? // EPL 승점 (KBO/LCK는 null)
  note   String? // 득실차(EPL)·게임차(KBO)·세트(LCK) 등 표시 보조
  asOf   DateTime @default(now())

  @@index([league])
}
