# Neon(https://neon.tech) 등에서 발급받은 PostgreSQL 연결 문자열
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# 로컬 개발용. Vercel에서는 설정하지 않아도 자동 감지됩니다.
NEXTAUTH_URL="http://localhost:3000"  # 배포 후 예: https://fanarena.com

# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET="change-me"

# ── 이메일 발송 (Resend: https://resend.com) ──
# 없으면 메일이 실제로 안 나가고 콘솔에 링크만 출력됩니다(개발용).
RESEND_API_KEY=""
# 도메인 인증 전이면 비워두세요(onboarding@resend.dev 사용). 인증 후 예: "Fan Arena <noreply@fanarena.kr>"
EMAIL_FROM=""

# ── 요청 제한 (Upstash Redis: https://upstash.com) ──
# 없으면 rate limiting이 비활성(항상 통과)됩니다. 서버리스에서 정확한 제한을 원하면 설정하세요.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
